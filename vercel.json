{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/debunker-passport/index.html" },
    { "source": "/styles.css", "destination": "/debunker-passport/styles.css" },
    { "source": "/app.js", "destination": "/debunker-passport/app.js" },
    { "source": "/risk-engine.js", "destination": "/debunker-passport/risk-engine.js" },
    { "source": "/demo-case.json", "destination": "/debunker-passport/demo-case.json" },
    { "source": "/passport-schema.json", "destination": "/debunker-passport/passport-schema.json" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
